rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper: Validate User Data
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 50 &&
             data.xp is number && data.xp >= 0 &&
             data.streak is number && data.streak >= 0;
    }

    // Helper: Validate Challenge Data
    function isValidChallenge(data) {
      return data.bookId is string && data.bookId.size() <= 100 &&
             data.sectionId is string && data.sectionId.size() <= 100 &&
             data.status in ['open', 'active', 'finished'] &&
             data.creatorId == request.auth.uid;
    }

    // Helper: Validate Participant Data
    function isValidParticipant(data) {
      return data.displayName is string && data.displayName.size() <= 50 &&
             data.score is number && data.score >= 0;
    }

    // match blocks
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow reading profile
      allow list: if false; // No blanket listing of users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'xp', 'streak', 'avatar', 'lastActive']);
    }

    match /challenges/{challengeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && existing().status == 'open'; // Only list open challenges
      allow create: if isSignedIn() && isValidChallenge(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        // Creator can update status
        (isOwner(existing().creatorId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    match /challenges/{challengeId}/participants/{participantId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isOwner(participantId) && isValidParticipant(incoming()) && incoming().joinedAt == request.time;
      allow update: if isOwner(participantId) && isValidParticipant(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['score', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }
  }
}
